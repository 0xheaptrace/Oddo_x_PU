generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  name                String
  avatarUrl           String?
  language            String   @default("en")
  preferences         String?
  savedDestinationIds String   @default("[]")
  resetToken          String?
  resetTokenExpires   DateTime?
  role                String   @default("USER")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  trips               Trip[]
  tripAccessRequests  TripAccessRequest[]
}

model Trip {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  startDate       DateTime
  endDate         DateTime
  destination     String
  coverImageUrl   String?
  status          String        @default("DRAFT")
  currency        String        @default("INR")
  travelers       Int           @default(1)
  shareSlug       String?       @unique
  shareMode       String        @default("PRIVATE") // PRIVATE | UNLISTED | PUBLIC
  sharePassword   String?       // bcrypt hash if set
  isPublic        Boolean       @default(false) // kept for compatibility (PUBLIC)
  budgetCap       Float?
  stops           Stop[]
  budgetLines     BudgetLine[]
  packingLists    PackingList[]
  notes           TripNote[]
  accessRequests  TripAccessRequest[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

model TripAccessRequest {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User     @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  message     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tripId])
  @@index([requesterId])
  @@unique([tripId, requesterId])
}

model Stop {
  id                String     @id @default(cuid())
  tripId            String
  trip              Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  sortOrder         Int        @default(0)
  city              String
  country           String?
  arrivalDate       DateTime?
  departureDate     DateTime?
  stayNights        Int?
  hotelName         String?
  hotelNotes        String?
  transportFromPrev String?
  transportNotes    String?
  lat               Float?
  lng               Float?
  activities        Activity[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([tripId])
}

model Activity {
  id               String    @id @default(cuid())
  stopId           String
  stop             Stop      @relation(fields: [stopId], references: [id], onDelete: Cascade)
  title            String
  category         String    @default("OTHER")
  status           String    @default("PLANNED") // PLANNED | BOOKED | DONE
  assignedTo       String?   // simple collaboration field (name/email)
  description      String?
  startTime        DateTime?
  endTime          DateTime?
  durationMinutes  Int?
  cost             Float?
  imageUrl         String?
  address          String?
  rating           Float?
  transportMode    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([stopId])
}

model BudgetLine {
  id        String    @id @default(cuid())
  tripId    String
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  category  String
  label     String
  amount    Float
  date      DateTime?
  createdAt DateTime  @default(now())

  @@index([tripId])
}

model PackingList {
  id        String        @id @default(cuid())
  tripId    String
  trip      Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name      String        @default("Main")
  template  String?
  items     PackingItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([tripId])
}

model PackingItem {
  id            String        @id @default(cuid())
  packingListId String
  packingList   PackingList   @relation(fields: [packingListId], references: [id], onDelete: Cascade)
  category      String        @default("OTHER")
  label         String
  packed        Boolean       @default(false)
  sortOrder     Int           @default(0)

  @@index([packingListId])
}

model TripNote {
  id          String    @id @default(cuid())
  tripId      String
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  dayDate     DateTime?
  title       String?
  content     String
  reminderAt  DateTime?
  contactInfo String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tripId])
}

model Destination {
  id               String  @id @default(cuid())
  name             String
  country          String
  slug             String  @unique
  imageUrl         String?
  popularity       Int     @default(50)
  avgCostPerDay    Int?
  attractionsCount Int?
  lat              Float?
  lng              Float?
  weatherSummary   String?
}

model BrowseActivity {
  id              String  @id @default(cuid())
  title           String
  category        String
  city            String
  country         String
  description     String?
  durationMinutes Int?
  priceEstimate   Int?
  rating          Float?
  imageUrl        String?
}
