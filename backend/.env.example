# SQLite (default for local dev). For PostgreSQL use docker-compose and set e.g.:
# DATABASE_URL="postgresql://traveloop:traveloop@localhost:5432/traveloop"
DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN="http://localhost:5173"
UPLOAD_DIR="./uploads"
PUBLIC_BASE_URL="http://localhost:4000"

# Optional: Cloudinary (if set, cover uploads use Cloudinary instead of local disk)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
